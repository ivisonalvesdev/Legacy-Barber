# ═══════════════════════════════════════════════════════════════
#  Legacy Barber — variáveis de ambiente
#
#  Copie para ".env" e preencha:  cp .env.example .env
#  Guia completo de cada integração:  docs/INTEGRACOES.md
#
#  REGRA DE OURO:
#   - VITE_*  → vão para o navegador (PÚBLICAS). Nunca coloque segredo aqui.
#   - sem VITE_ → ficam só no servidor/scripts (n8n, Edge Functions, .mjs).
# ═══════════════════════════════════════════════════════════════

# ── Supabase (obrigatório) ──────────────────────────────────────
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=cole_sua_anon_key

# Service role — só para os scripts em /scripts. NUNCA vai para o frontend.
# Supabase Dashboard → Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=cole_sua_service_role_key

# Session pooler — só para scripts/apply-sql.mjs. Escape caracteres da senha
# (o @ vira %40). Dashboard → Settings → Database → Connection string.
DATABASE_URL=postgresql://postgres.PROJETO:SENHA@aws-1-sa-east-1.pooler.supabase.com:5432/postgres


# ═══════════════════════════════════════════════════════════════
#  CLIENT-SAFE — funcionam já, sem chave nenhuma (nada a configurar)
#   • ViaCEP    — endereço a partir do CEP     (cadastro da barbearia)
#   • BrasilAPI — dados da empresa pelo CNPJ    (cadastro da barbearia)
#  Não precisam de variável: são APIs públicas e gratuitas.
# ═══════════════════════════════════════════════════════════════


# ═══════════════════════════════════════════════════════════════
#  A CONFIGURAR DEPOIS (deixe em branco por enquanto)
# ═══════════════════════════════════════════════════════════════

# ── n8n — automação (WhatsApp, e-mail, lembretes) ───────────────
# É o coração da automação (planejado para o final do projeto). O app já
# dispara os eventos "booking.created" para esta URL. Crie um nó Webhook no
# n8n e cole a Production URL aqui.
VITE_N8N_WEBHOOK_URL=

# ── Google Maps / Places (autocomplete de endereço + mapa) ──────
# console.cloud.google.com → ative "Places API" e "Maps JavaScript API".
# Restrinja a chave por domínio (é pública, vai no browser).
VITE_GOOGLE_MAPS_API_KEY=

# ── OneSignal — Web Push (aviso de novo agendamento) ────────────
# onesignal.com → New App → Web. O App ID é público; a REST API Key é
# secreta e fica no n8n/servidor (NÃO aqui embaixo com VITE_).
VITE_ONESIGNAL_APP_ID=


# ═══════════════════════════════════════════════════════════════
#  SEGREDOS SERVER-SIDE — NÃO colocar no .env do Vite!
#
#  Estas chaves NUNCA podem ir para o navegador. Configure-as dentro do
#  n8n (Credentials) ou em Supabase Edge Functions. Ficam aqui só como
#  referência do que cada automação vai precisar. Ver docs/INTEGRACOES.md.
#
#   WhatsApp .......... TWILIO_* ou ZAPI_TOKEN / ZAPI_INSTANCE
#   Pagamento ......... MERCADOPAGO_ACCESS_TOKEN ou STRIPE_SECRET_KEY
#   E-mail ............ RESEND_API_KEY ou SENDGRID_API_KEY
#   Push (servidor) ... ONESIGNAL_REST_API_KEY
#   Instagram ......... INSTAGRAM_ACCESS_TOKEN
# ═══════════════════════════════════════════════════════════════
